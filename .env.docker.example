# Biến cho docker-compose (interpolation). Sao chép thành .env cạnh docker-compose.yml:
#   cp .env.docker.example .env
# Lưu ý: đây là env cho COMPOSE, khác .env.local (dùng khi chạy `npm run dev` không qua Docker).

# Mặc định: KHÔNG đặt MONGODB_URI ở đây -> compose tự fallback về mongo container
#   (mongodb://mongo:27017/nxstalgia). Muốn dùng Atlas thì bỏ comment dòng dưới.
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nxstalgia?retryWrites=true&w=majority&appName=Cluster0

# Bí mật ký JWT — đổi thành chuỗi ngẫu nhiên dài (vd: openssl rand -hex 32)
JWT_SECRET=doi-thanh-chuoi-ngau-nhien-that-dai

# Thời hạn token (giây) — mặc định 7 ngày
JWT_TTL=604800

# Tài khoản admin đầu tiên (dùng cho `npm run create-admin`)
ADMIN_EMAIL=admin@nxstalgia.local
ADMIN_PASSWORD=doi-mat-khau-nay

# Muốn dùng MongoDB Atlas thay cho container mongo:
#  - xoá/không dùng service mongo trong docker-compose.yml, hoặc
#  - bỏ comment dòng MONGODB_URI ở trên (compose sẽ ưu tiên biến này).
