# Sao chép file này thành .env.local rồi điền giá trị thật

# Chuỗi kết nối MongoDB (local hoặc Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/nxstalgia

# Bí mật ký JWT — đổi thành chuỗi ngẫu nhiên dài (vd: openssl rand -hex 32)
JWT_SECRET=doi-thanh-chuoi-ngau-nhien-that-dai

# Thời hạn token (giây) — mặc định 7 ngày
JWT_TTL=604800

# Tài khoản admin đầu tiên (dùng cho `npm run create-admin`)
ADMIN_EMAIL=admin@nxstalgia.local
ADMIN_PASSWORD=doi-mat-khau-nay
